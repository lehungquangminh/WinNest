{
  "schemaVersion": 1,
  "id": "zalo",
  "name": "Zalo",
  "match": {
    "installerNames": ["zalo", "zalo setup", "zalosetup"],
    "publisherNames": ["VNG", "Zalo"]
  },
  "systemDeps": ["wine32", "winbind"],
  "wineDeps": [],
  "permissions": {
    "microphone": true,
    "camera": true,
    "downloads": true
  },
  "notes": [
    "Voice and video calling may require microphone/camera integration.",
    "System tray behavior may depend on desktop environment.",
    "Chromium GPU rendering is disabled by default to avoid blank white windows under Wine."
  ],
  "expectedExecutables": ["Zalo.exe"],
  "categories": ["Network", "Chat"],
  "launchArgs": [
    "--disable-gpu",
    "--disable-gpu-compositing",
    "--disable-features=UseSkiaRenderer,CanvasOopRasterization"
  ]
}
