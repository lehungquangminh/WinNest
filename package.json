{
  "name": "winnest",
  "version": "0.1.0",
  "description": "A TypeScript-only Linux desktop and CLI app manager for Windows software through Wine.",
  "type": "module",
  "main": "./dist/main/index.js",
  "bin": {
    "winnest": "./dist/cli/index.js",
    "winnest-open": "./dist/cli/open.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:gui": "npm run build && vite build",
    "build:deb": "bash scripts/build-deb.sh",
    "build:apt-repo": "bash scripts/build-apt-repo.sh",
    "publish:apt-pages": "bash scripts/publish-apt-pages.sh",
    "qa:deb": "bash scripts/qa-deb.sh",
    "checksums": "bash scripts/checksums.sh",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "dev:cli": "node --enable-source-maps ./dist/cli/index.js",
    "start:gui": "electron ./dist/main/index.js",
    "test:path-torture": "tsx tests/path-torture.ts",
    "test:real-install": "tsx tests/real-install.ts",
    "link:dev": "npm link",
    "unlink:dev": "npm unlink -g winnest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0",
  "devDependencies": {
    "@types/node": "^24.0.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vite": "^8.1.3"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
